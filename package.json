{
  "name": "mind-voyage-companion",
  "version": "1.0.0",
  "description": "A privacy-first habit tracking and journaling application designed to help users build consistent routines, engage in reflective writing with Stoic-inspired prompts, and improve their English through journal-based language learning.",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "pnpm db:cleanup && pnpm dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "db:cleanup": "echo 'Cleaning up MongoDB Memory Server instances...' && pkill -f mongod || true",
    "test": "echo 'Unit testing infrastructure will be configured in MVC-002 or later user stories'",
    "test:ui": "echo 'Unit testing infrastructure will be configured in MVC-002 or later user stories'",
    "test:run": "echo 'Unit testing infrastructure will be configured in MVC-002 or later user stories'",
    "test:coverage": "echo 'Unit testing infrastructure will be configured in MVC-002 or later user stories'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "postinstall": "husky install"
  },
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "habit-tracking",
    "journaling",
    "stoic",
    "mindfulness"
  ],
  "author": "Mind Voyage Team",
  "license": "MIT",
  "dependencies": {
    "@auth/mongodb-adapter": "^3.10.0",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-query-devtools": "^5.87.4",
    "@types/node": "^24.3.3",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.544.0",
    "mongodb": "^6.18.0",
    "mongoose": "^8.18.1",
    "next": "^15.5.3",
    "next-auth": "5.0.0-beta.29",
    "next-intl": "^4.3.8",
    "nuqs": "^2.6.0",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.3",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.1.6",
    "mongodb-memory-server": "^10.2.0",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  }
}
