# =============================================================================
# Next.js MVP Boilerplate - Environment Configuration
# =============================================================================
# Copy this file to .env.local and update the values
# NEVER commit .env.local to version control
#
# Quick Start:
# 1. cp .env.example .env.local
# 2. pnpm generate:secrets   (generates JWT_SECRET and NEXTAUTH_SECRET)
# 3. Update MONGODB_URI with your database connection
# 4. pnpm dev
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Application URL (update for production)
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/your_database_name

# -----------------------------------------------------------------------------
# Authentication Secrets (REQUIRED)
# -----------------------------------------------------------------------------
# Generate secure secrets using: pnpm generate:secrets

# JWT secret for API authentication (48+ chars recommended)
JWT_SECRET=change_this_to_a_secure_random_string_minimum_32_characters

# NextAuth secret for session management (48+ chars recommended)
NEXTAUTH_SECRET=change_this_to_a_secure_random_string_minimum_32_characters

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# -----------------------------------------------------------------------------
# Microsoft Entra ID (formerly Azure AD)
# AZURE_AD_CLIENT_ID=your_client_id_here
# AZURE_AD_CLIENT_SECRET=your_client_secret_here
# AZURE_AD_TENANT_ID=your_tenant_id_here
