# Mind Voyage Companion - Environment Configuration Example
# Copy this file to .env and update the values as needed

# =============================================================================
# Database Configuration
# =============================================================================
# MongoDB connection for development (localhost) and Docker (mongodb service name)
# For local development with Docker MongoDB:
MONGODB_URI=mongodb://mindvoyage_user:mindvoyage_pass_2025@localhost:27017/mind_voyage_companion?authSource=mind_voyage_companion

# For Docker Compose (internal network):
# MONGODB_URI=mongodb://mindvoyage_user:mindvoyage_pass_2025@mongodb:27017/mind_voyage_companion?authSource=mind_voyage_companion

# MongoDB credentials
MONGODB_USERNAME=mindvoyage_user
MONGODB_PASSWORD=mindvoyage_pass_2025
MONGODB_ROOT_PASSWORD=mindvoyage_admin_2025

# =============================================================================
# Application Configuration
# =============================================================================
# Next.js configuration (set to development for local work)
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Application URL
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret (generate a secure random string for production)
NEXTAUTH_SECRET=your_nextauth_secret_here_min_32_chars_change_in_production

# =============================================================================
# Port Configuration
# =============================================================================
# Application port
APP_PORT=3000

# MongoDB port
MONGODB_PORT=27017

# Mongo Express admin interface port
MONGO_EXPRESS_PORT=8081

# =============================================================================
# Admin Interface Configuration (Optional)
# =============================================================================
# Mongo Express credentials
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=admin123

# =============================================================================
# Security Configuration
# =============================================================================
# JWT secret for API authentication (generate a secure random string)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Email configuration (if using email features)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# =============================================================================
# Development Configuration
# =============================================================================
# Set to false to disable MongoDB Memory Server in development
# USE_MEMORY_SERVER=false
