# Mind Voyage Companion - Docker Ignore Configuration
# Exclude files and directories that should not be included in Docker build context

# =============================================================================
# Git and Version Control
# =============================================================================
.git
.gitignore
.github
.gitattributes

# =============================================================================
# Dependencies and Build Output
# =============================================================================
node_modules
.next
out
dist
build

# =============================================================================
# Development Files
# =============================================================================
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Environment and Configuration
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# =============================================================================
# Logs and Debugging
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# =============================================================================
# Testing and Coverage
# =============================================================================
coverage
.nyc_output
test-results
playwright-report
.playwright

# =============================================================================
# Documentation and README
# =============================================================================
README.md
CHANGELOG.md
LICENSE
docs

# =============================================================================
# Docker Files (exclude from context when building)
# =============================================================================
Dockerfile*
.dockerignore
docker-compose*.yml

# =============================================================================
# Temporary Files
# =============================================================================
.tmp
.temp
tmp
temp

# =============================================================================
# MongoDB and Database
# =============================================================================
mongodb-binaries
data

# =============================================================================
# Package Manager Files (already copied separately)
# =============================================================================
.pnpm-store
.npm
.yarn

# =============================================================================
# TypeScript Build Info
# =============================================================================
*.tsbuildinfo

# =============================================================================
# Storybook
# =============================================================================
.storybook
storybook-static

# =============================================================================
# ESLint and Prettier
# =============================================================================
.eslintcache

# =============================================================================
# Miscellaneous
# =============================================================================
.vercel
.turbo
.cache