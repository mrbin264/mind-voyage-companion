# Environment Configuration for Docker MongoDB Migration
# Copy these variables to your .env.local file

# =============================================================================
# MongoDB Docker Configuration
# =============================================================================

# Docker MongoDB Connection (replaces Memory Server)
MONGODB_URI=mongodb://mindvoyage_user:mindvoyage_pass_2025@localhost:27017/mind_voyage_companion?authSource=mind_voyage_companion

# Docker MongoDB Admin Credentials (for mongo-express)
MONGODB_ROOT_PASSWORD=mindvoyage_admin_2025
MONGODB_USERNAME=mindvoyage_user
MONGODB_PASSWORD=mindvoyage_pass_2025

# Optional: Custom ports (defaults shown)
MONGODB_PORT=27017
MONGO_EXPRESS_PORT=8081

# =============================================================================
# NextAuth Configuration (generate new secrets)
# =============================================================================

# Generate new secrets using: pnpm generate:secrets
NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_generated_secret_here
# JWT_SECRET=your_generated_jwt_secret_here

# =============================================================================
# Application Configuration
# =============================================================================

# Environment
NODE_ENV=development

# Application port
APP_PORT=3000

# =============================================================================
# Optional: Production Configuration
# =============================================================================

# For production deployments, update these:
# MONGODB_URI=mongodb://username:password@production-host:27017/mind_voyage_companion
# NEXTAUTH_URL=https://your-production-domain.com
# NODE_ENV=production

# =============================================================================
# Security Notes
# =============================================================================

# 🔒 Security Checklist:
# □ Use different credentials for each environment
# □ Generate strong, unique secrets for production
# □ Never commit secrets to version control
# □ Use environment-specific configuration files
# □ Enable MongoDB authentication in production
# □ Use TLS/SSL for production database connections

# 📋 Quick Setup Commands:
# 1. Copy to .env.local: cp .env.docker.example .env.local
# 2. Generate secrets: pnpm generate:secrets
# 3. Start MongoDB: docker-compose up mongodb -d
# 4. Start development: pnpm dev

# 🔍 Verification Commands:
# - Check MongoDB: docker-compose logs mongodb
# - Test connection: pnpm docker:health
# - View database: http://localhost:8081 (mongo-express)