{
  "$schema": "https://schemas.tokens.studio/sd.json",
  "meta": {
    "name": "Mind Voyage Tokens",
    "version": "1.0.0",
    "source": "Auth Flow + Landing",
    "created": "2025-09-15"
  },
  "options": {
    "prefix": "mv",
    "outputReferences": true
  },
  "themes": [
    {
      "id": "light",
      "name": "Light",
      "selectedTokenSets": {
        "core": "enabled",
        "semantic.light": "enabled",
        "semantic.dark": "disabled"
      }
    },
    {
      "id": "dark",
      "name": "Dark",
      "selectedTokenSets": {
        "core": "enabled",
        "semantic.light": "disabled",
        "semantic.dark": "enabled"
      }
    }
  ],
  "tokenSets": {
    "core": {
      "fontFamilies": {
        "ui": { "value": "Inter" },
        "serif": { "value": "Spectral" }
      },
      "fontSizes": {
        "h1": { "value": 56 },
        "h2": { "value": 40 },
        "h3": { "value": 28 },
        "body": { "value": 16 },
        "small": { "value": 14 }
      },
      "lineHeights": {
        "h1": { "value": 64 },
        "h2": { "value": 48 },
        "h3": { "value": 36 },
        "body": { "value": 24 },
        "small": { "value": 20 }
      },
      "fontWeights": {
        "regular": { "value": 400 },
        "medium": { "value": 500 },
        "semibold": { "value": 600 },
        "bold": { "value": 700 }
      },
      "spacing": {
        "s4": { "value": 4 },
        "s8": { "value": 8 },
        "s12": { "value": 12 },
        "s16": { "value": 16 },
        "s20": { "value": 20 },
        "s24": { "value": 24 },
        "s28": { "value": 28 },
        "s32": { "value": 32 },
        "s40": { "value": 40 },
        "s48": { "value": 48 },
        "s56": { "value": 56 },
        "s64": { "value": 64 },
        "s80": { "value": 80 }
      },
      "radii": {
        "sm": { "value": 8 },
        "md": { "value": 12 },
        "lg": { "value": 16 },
        "xl": { "value": 24 }
      },
      "shadows": {
        "card": { "value": "0 6 18 rgba(15,23,42,0.08)" },
        "focus": { "value": "0 0 0 4 rgba(109,90,229,0.25)" }
      },
      "easings": {
        "standard": { "value": "cubic-bezier(0.2, 0, 0, 1)" },
        "emphasized": { "value": "cubic-bezier(0.2, 0, 0, 1)" }
      },
      "durations": {
        "fast": { "value": 150 },
        "base": { "value": 200 },
        "slow": { "value": 300 }
      },
      "zIndex": {
        "dropdown": { "value": 1000 },
        "modal": { "value": 1100 },
        "toast": { "value": 1200 }
      },
      "breakpoints": {
        "mobile": { "value": 0 },
        "tablet": { "value": 768 },
        "desktop": { "value": 1200 }
      },
      "palette": {
        "brand.primary": { "value": "#6D5AE5" },
        "brand.primary.600": { "value": "#5548D9" },
        "accent.cyan": { "value": "#22D3EE" },
        "neutral.900": { "value": "#0F172A" },
        "neutral.700": { "value": "#334155" },
        "neutral.500": { "value": "#64748B" },
        "neutral.200": { "value": "#E2E8F0" },
        "neutral.50": { "value": "#F8FAFC" },
        "success.500": { "value": "#22C55E" },
        "warning.500": { "value": "#F59E0B" },
        "danger.500": { "value": "#EF4444" },
        "info.500": { "value": "#0EA5E9" }
      }
    },
    "semantic.light": {
      "color.bg": { "value": "{core.palette.neutral.50}" },
      "color.surface": { "value": "#FFFFFF" },
      "color.text": { "value": "{core.palette.neutral.900}" },
      "color.textSubtle": { "value": "{core.palette.neutral.700}" },
      "color.border": { "value": "{core.palette.neutral.200}" },
      "color.cta": { "value": "{core.palette.brand.primary}" },
      "color.ctaText": { "value": "#FFFFFF" },
      "color.success": { "value": "{core.palette.success.500}" },
      "color.warning": { "value": "{core.palette.warning.500}" },
      "color.danger": { "value": "{core.palette.danger.500}" },
      "color.info": { "value": "{core.palette.info.500}" },
      "form.inputBg": { "value": "#FFFFFF" },
      "form.inputText": { "value": "{semantic.light.color.text}" },
      "form.inputPlaceholder": { "value": "{core.palette.neutral.500}" },
      "form.inputBorder": { "value": "{semantic.light.color.border}" },
      "form.focusRing": { "value": "{core.shadows.focus}" }
    },
    "semantic.dark": {
      "color.bg": { "value": "#0B1220" },
      "color.surface": { "value": "#0F172A" },
      "color.text": { "value": "#E5E7EB" },
      "color.textSubtle": { "value": "#CBD5E1" },
      "color.border": { "value": "#1F2937" },
      "color.cta": { "value": "{core.palette.brand.primary.600}" },
      "color.ctaText": { "value": "#FFFFFF" },
      "color.success": { "value": "{core.palette.success.500}" },
      "color.warning": { "value": "{core.palette.warning.500}" },
      "color.danger": { "value": "{core.palette.danger.500}" },
      "color.info": { "value": "{core.palette.info.500}" },
      "form.inputBg": { "value": "#0F172A" },
      "form.inputText": { "value": "{semantic.dark.color.text}" },
      "form.inputPlaceholder": { "value": "#94A3B8" },
      "form.inputBorder": { "value": "{semantic.dark.color.border}" },
      "form.focusRing": { "value": "{core.shadows.focus}" }
    }
  },
  "components": {
    "button": {
      "height.md": { "value": 40 },
      "height.lg": { "value": 48 },
      "paddingX": { "value": 20 },
      "paddingY": { "value": 12 },
      "gap": { "value": 8 },
      "radius": { "value": "{core.radii.lg}" },
      "primary.bg": {
        "value": "{semantic.light.color.cta}",
        "$extensions": { "mode": { "dark": "{semantic.dark.color.cta}" } }
      },
      "primary.fg": {
        "value": "{semantic.light.color.ctaText}",
        "$extensions": { "mode": { "dark": "{semantic.dark.color.ctaText}" } }
      },
      "secondary.bg": { "value": "transparent" },
      "secondary.border": {
        "value": "{semantic.light.color.border}",
        "$extensions": { "mode": { "dark": "{semantic.dark.color.border}" } }
      }
    },
    "input": {
      "height": { "value": 48 },
      "paddingX": { "value": 12 },
      "radius": { "value": "{core.radii.xl}" },
      "bg": {
        "value": "{semantic.light.form.inputBg}",
        "$extensions": { "mode": { "dark": "{semantic.dark.form.inputBg}" } }
      },
      "fg": {
        "value": "{semantic.light.form.inputText}",
        "$extensions": { "mode": { "dark": "{semantic.dark.form.inputText}" } }
      },
      "placeholder": {
        "value": "{semantic.light.form.inputPlaceholder}",
        "$extensions": { "mode": { "dark": "{semantic.dark.form.inputPlaceholder}" } }
      },
      "border": {
        "value": "{semantic.light.form.inputBorder}",
        "$extensions": { "mode": { "dark": "{semantic.dark.form.inputBorder}" } }
      },
      "focusRing": { "value": "{core.shadows.focus}" },
      "error.border": { "value": "{semantic.light.color.danger}" },
      "success.border": { "value": "{semantic.light.color.success}" }
    },
    "checkbox": {
      "size": { "value": 20 },
      "radius": { "value": 6 }
    },
    "banner": {
      "radius": { "value": "{core.radii.lg}" },
      "padding": { "value": "{core.spacing.s16}" }
    },
    "toast": {
      "radius": { "value": "{core.radii.md}" },
      "zIndex": { "value": "{core.zIndex.toast}" }
    }
  },
  "authFlow": {
    "container.desktopMax": { "value": 1040 },
    "container.tabletMax": { "value": 720 },
    "card.paddingDesktop": { "value": 32 },
    "card.paddingMobile": { "value": 16 },
    "aside.widthDesktop": { "value": 520 }
  }
}
